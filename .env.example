# Google OAuth Client ID (Web Application type)
# Create at: https://console.cloud.google.com/apis/credentials
# Add your GitHub Pages URL to Authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# OPTIONAL — enables true permanent auth via the Cloudflare Worker
# backend in ./worker (refresh tokens stored server-side). Leave unset
# to use browser-only auth (1-hour tokens + silent refresh). See
# worker/README.md for deployment instructions.
# VITE_AUTH_BACKEND_URL=https://google-ai-workspace-auth.your-account.workers.dev
